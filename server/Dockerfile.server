FROM python:3.10-slim

WORKDIR /app

# Copy unified requirements from root context
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy web server deployment code into workspace
COPY server/main.py .

EXPOSE 8000

# Fire up uvicorn server mapping network ports
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
